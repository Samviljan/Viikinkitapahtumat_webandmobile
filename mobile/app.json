{
  "expo": {
    "name": "Viikinkitapahtumat",
    "slug": "viikinkitapahtumat",
    "version": "0.4.12",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "viikinki",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0E0B09"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "fi.viikinkitapahtumat.mobile",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Käytämme sijaintiasi näyttääksemme lähimmät viikinkitapahtumat."
      }
    },
    "android": {
      "package": "fi.viikinkitapahtumat.mobile",
      "versionCode": 26,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0E0B09"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.POST_NOTIFICATIONS",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.POST_NOTIFICATIONS",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "runtimeVersion": {
        "policy": "appVersion"
      }
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#0E0B09"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Käytämme sijaintiasi näyttääksemme lähimmät viikinkitapahtumat."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#C9A14A",
          "defaultChannel": "default"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "baseUrl": "/api/mobile-app"
    },
    "extra": {
      "apiBaseUrl": "https://viikinkitapahtumat.fi",
      "router": {},
      "eas": {
        "projectId": "73281723-f172-4938-8fc0-c1feee70bc51"
      }
    },
    "owner": "samviljan",
    "updates": {
      "url": "https://u.expo.dev/73281723-f172-4938-8fc0-c1feee70bc51"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
