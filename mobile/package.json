{
  "name": "viikinkitapahtumat-mobile",
  "version": "0.1.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "bump:patch": "node scripts/bump-version.js patch",
    "bump:minor": "node scripts/bump-version.js minor",
    "bump:major": "node scripts/bump-version.js major",
    "build:prod": "node scripts/bump-version.js patch && eas build --platform android --profile production --non-interactive",
    "update:prod": "eas update --branch production"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "axios": "^1.7.9",
    "expo": "^54.0.0",
    "expo-constants": "~18.0.13",
    "expo-device": "^55.0.15",
    "expo-document-picker": "^55.0.13",
    "expo-font": "~14.0.11",
    "expo-image-picker": "^55.0.19",
    "expo-linking": "~8.0.11",
    "expo-localization": "^55.0.13",
    "expo-location": "~19.0.8",
    "expo-notifications": "^55.0.20",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.17",
    "expo-web-browser": "^55.0.14",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.1.10",
    "eas-cli": "^18.8.1",
    "typescript": "~5.9.2"
  },
  "private": true
}
